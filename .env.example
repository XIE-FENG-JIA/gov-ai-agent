# ============================================================
# 公文 AI Agent - 環境變數範本
# 複製此檔案為 .env 並填入您的設定值
#   cp .env.example .env
# ============================================================

# ------------------------------------------------------------
# LLM 提供者 API 金鑰
# ------------------------------------------------------------

# OpenRouter API Key（使用 OpenRouter 時必填）
# 取得方式：https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Gemini API Key（使用 Gemini 時必填）
# 取得方式：https://aistudio.google.com/apikey
GEMINI_API_KEY=

# MiniMax API Key（使用 MiniMax 時必填）
# 取得方式：MiniMax 開放平台
MINIMAX_API_KEY=

# 通用 LLM API Key（也可用此變數設定 OpenRouter 金鑰）
# 若同時設定 LLM_API_KEY 與 OPENROUTER_API_KEY，CLI 會優先使用 LLM_API_KEY
LLM_API_KEY=

# LLM 模型名稱（對應 config.yaml 中的 ${LLM_MODEL}）
# 範例：google/gemini-2.5-pro、meta-llama/llama-3.1-8b-instruct:free
LLM_MODEL=

# ------------------------------------------------------------
# API Server 設定（api_server.py）
# ------------------------------------------------------------

# 監聽位址（預設：0.0.0.0）
API_HOST=0.0.0.0

# 監聽埠號（預設：8000）
API_PORT=8000

# Uvicorn worker 數量（預設：1）
API_WORKERS=1

# 日誌等級：DEBUG, INFO, WARNING, ERROR（預設：INFO）
LOG_LEVEL=INFO

# ------------------------------------------------------------
# API 速率限制與逾時
# ------------------------------------------------------------

# 每分鐘請求上限（預設：30）
RATE_LIMIT_RPM=30

# 一般端點逾時秒數（預設：180）
API_ENDPOINT_TIMEOUT=180

# 完整工作流（meeting）逾時秒數（預設：600）
API_MEETING_TIMEOUT=600

# ------------------------------------------------------------
# CORS 跨域設定
# ------------------------------------------------------------

# 允許的來源，以逗號分隔
# 預設：http://localhost:5678,http://localhost:3000,http://localhost:8080
CORS_ALLOWED_ORIGINS=http://localhost:5678,http://localhost:3000,http://localhost:8080

# 是否允許攜帶憑證（Cookie 等）（預設：false）
CORS_ALLOW_CREDENTIALS=false

# ------------------------------------------------------------
# 安全性設定
# ------------------------------------------------------------

# 啟用 HSTS 標頭（生產環境建議啟用）（預設：false）
HTTPS_ENABLED=false

# 信任反向代理的 X-Forwarded-For 標頭（預設：false）
TRUST_PROXY=false

# 寫入型 API 端點 Bearer 金鑰；多組 key 以逗號分隔
# 範例：API_CLIENT_KEY=prod-key-1,prod-key-2
# 未設定時視為本機開發模式，寫入端點不做 route-level Bearer 驗證
API_CLIENT_KEY=

# ------------------------------------------------------------
# API 文件
# ------------------------------------------------------------

# 啟用 Swagger UI (/docs) 與 ReDoc (/redoc)（預設：true）
# 生產環境可設為 false 關閉
ENABLE_API_DOCS=true

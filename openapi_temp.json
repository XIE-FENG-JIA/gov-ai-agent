{"openapi":"3.1.0","info":{"title":"公文 AI Agent API","description":"n8n 整合用的公文 AI Agent REST API。\n\n提供公文需求分析、草稿撰寫、多 Agent 審查、自動修正等功能。\n\n## 端點分類\n- **健康檢查**: 伺服器狀態查詢\n- **需求分析**: 自然語言轉結構化需求\n- **草稿撰寫**: 依需求產生公文草稿\n- **審查**: 格式、文風、事實、一致性、合規性審查\n- **修改**: 依審查意見修正草稿\n- **完整流程**: 一鍵完成需求→撰寫→審查→修改→輸出","version":"2.0.0"},"paths":{"/":{"get":{"tags":["健康檢查"],"summary":"Root","description":"基本健康檢查\n\n回傳伺服器狀態、API 版本號及時間戳記。","operationId":"root__get","responses":{"200":{"description":"Successful Response","content":{"application/json":{"schema":{"additionalProperties":{"type":"string"},"type":"object","title":"Response Root  Get"}}}}}}},"/api/v1/health":{"get":{"tags":["健康檢查"],"summary":"Health Check","description":"詳細健康檢查\n\n回傳 LLM 提供者與模型資訊（不洩漏檔案路徑等敏感資訊）。","operationId":"health_check_api_v1_health_get","responses":{"200":{"description":"Successful Response","content":{"application/json":{"schema":{"additionalProperties":{"type":"string"},"type":"object","title":"Response Health Check Api V1 Health Get"}}}}}}},"/api/v1/agent/requirement":{"post":{"tags":["需求分析"],"summary":"Analyze Requirement","description":"需求分析 Agent\n\n將用戶的自然語言描述轉換為結構化的公文需求（doc_type, sender, receiver 等）。","operationId":"analyze_requirement_api_v1_agent_requirement_post","requestBody":{"content":{"application/json":{"schema":{"$ref":"#/components/schemas/RequirementRequest"}}},"required":true},"responses":{"200":{"description":"Successful Response","content":{"application/json":{"schema":{"$ref":"#/components/schemas/RequirementResponse"}}}},"422":{"description":"Validation Error","content":{"application/json":{"schema":{"$ref":"#/components/schemas/HTTPValidationError"}}}}}}},"/api/v1/agent/writer":{"post":{"tags":["草稿撰寫"],"summary":"Write Draft","description":"撰寫 Agent\n\n根據結構化需求（來自 requirement agent）撰寫公文草稿，\n並套用標準模板格式。","operationId":"write_draft_api_v1_agent_writer_post","requestBody":{"content":{"application/json":{"schema":{"$ref":"#/components/schemas/WriterRequest"}}},"required":true},"responses":{"200":{"description":"Successful Response","content":{"application/json":{"schema":{"$ref":"#/components/schemas/WriterResponse"}}}},"422":{"description":"Validation Error","content":{"application/json":{"schema":{"$ref":"#/components/schemas/HTTPValidationError"}}}}}}},"/api/v1/agent/review/format":{"post":{"tags":["審查"],"summary":"Review Format","description":"格式審查 Agent\n\n檢查公文是否符合標準格式規範（主旨、說明、辦法等段落結構）。","operationId":"review_format_api_v1_agent_review_format_post","requestBody":{"content":{"application/json":{"schema":{"$ref":"#/components/schemas/ReviewRequest"}}},"required":true},"responses":{"200":{"description":"Successful Response","content":{"application/json":{"schema":{"$ref":"#/components/schemas/ReviewResponse"}}}},"422":{"description":"Validation Error","content":{"application/json":{"schema":{"$ref":"#/components/schemas/HTTPValidationError"}}}}}}},"/api/v1/agent/review/style":{"post":{"tags":["審查"],"summary":"Review Style","description":"文風審查 Agent\n\n檢查公文用語是否正式、語氣是否得體。","operationId":"review_style_api_v1_agent_review_style_post","requestBody":{"content":{"application/json":{"schema":{"$ref":"#/components/schemas/ReviewRequest"}}},"required":true},"responses":{"200":{"description":"Successful Response","content":{"application/json":{"schema":{"$ref":"#/components/schemas/ReviewResponse"}}}},"422":{"description":"Validation Error","content":{"application/json":{"schema":{"$ref":"#/components/schemas/HTTPValidationError"}}}}}}},"/api/v1/agent/review/fact":{"post":{"tags":["審查"],"summary":"Review Fact","description":"事實審查 Agent\n\n檢查公文中的事實陳述、日期、法規引用是否正確。","operationId":"review_fact_api_v1_agent_review_fact_post","requestBody":{"content":{"application/json":{"schema":{"$ref":"#/components/schemas/ReviewRequest"}}},"required":true},"responses":{"200":{"description":"Successful Response","content":{"application/json":{"schema":{"$ref":"#/components/schemas/ReviewResponse"}}}},"422":{"description":"Validation Error","content":{"application/json":{"schema":{"$ref":"#/components/schemas/HTTPValidationError"}}}}}}},"/api/v1/agent/review/consistency":{"post":{"tags":["審查"],"summary":"Review Consistency","description":"一致性審查 Agent\n\n檢查公文內部邏輯是否一致、前後文是否矛盾。","operationId":"review_consistency_api_v1_agent_review_consistency_post","requestBody":{"content":{"application/json":{"schema":{"$ref":"#/components/schemas/ReviewRequest"}}},"required":true},"responses":{"200":{"description":"Successful Response","content":{"application/json":{"schema":{"$ref":"#/components/schemas/ReviewResponse"}}}},"422":{"description":"Validation Error","content":{"application/json":{"schema":{"$ref":"#/components/schemas/HTTPValidationError"}}}}}}},"/api/v1/agent/review/compliance":{"post":{"tags":["審查"],"summary":"Review Compliance","description":"政策合規審查 Agent\n\n檢查公文內容是否符合相關法規與政策要求。","operationId":"review_compliance_api_v1_agent_review_compliance_post","requestBody":{"content":{"application/json":{"schema":{"$ref":"#/components/schemas/ReviewRequest"}}},"required":true},"responses":{"200":{"description":"Successful Response","content":{"application/json":{"schema":{"$ref":"#/components/schemas/ReviewResponse"}}}},"422":{"description":"Validation Error","content":{"application/json":{"schema":{"$ref":"#/components/schemas/HTTPValidationError"}}}}}}},"/api/v1/agent/review/parallel":{"post":{"tags":["審查"],"summary":"Parallel Review","description":"並行審查\n\n同時執行多個審查 Agent（格式、文風、事實、一致性、合規），\n彙整加權分數與風險等級。","operationId":"parallel_review_api_v1_agent_review_parallel_post","requestBody":{"content":{"application/json":{"schema":{"$ref":"#/components/schemas/ParallelReviewRequest"}}},"required":true},"responses":{"200":{"description":"Successful Response","content":{"application/json":{"schema":{"$ref":"#/components/schemas/ParallelReviewResponse"}}}},"422":{"description":"Validation Error","content":{"application/json":{"schema":{"$ref":"#/components/schemas/HTTPValidationError"}}}}}}},"/api/v1/agent/refine":{"post":{"tags":["修改"],"summary":"Refine Draft","description":"Editor Agent\n\n根據審查 Agent 回傳的問題列表，自動修正公文草稿。","operationId":"refine_draft_api_v1_agent_refine_post","requestBody":{"content":{"application/json":{"schema":{"$ref":"#/components/schemas/RefineRequest"}}},"required":true},"responses":{"200":{"description":"Successful Response","content":{"application/json":{"schema":{"$ref":"#/components/schemas/RefineResponse"}}}},"422":{"description":"Validation Error","content":{"application/json":{"schema":{"$ref":"#/components/schemas/HTTPValidationError"}}}}}}},"/api/v1/meeting":{"post":{"tags":["完整流程"],"summary":"Run Meeting","description":"完整開會流程\n\n一鍵執行：需求分析 -> 撰寫 -> 審查 -> 修改 -> 輸出 DOCX。","operationId":"run_meeting_api_v1_meeting_post","requestBody":{"content":{"application/json":{"schema":{"$ref":"#/components/schemas/MeetingRequest"}}},"required":true},"responses":{"200":{"description":"Successful Response","content":{"application/json":{"schema":{"$ref":"#/components/schemas/MeetingResponse"}}}},"422":{"description":"Validation Error","content":{"application/json":{"schema":{"$ref":"#/components/schemas/HTTPValidationError"}}}}}}}},"components":{"schemas":{"HTTPValidationError":{"properties":{"detail":{"items":{"$ref":"#/components/schemas/ValidationError"},"type":"array","title":"Detail"}},"type":"object","title":"HTTPValidationError"},"MeetingRequest":{"properties":{"user_input":{"type":"string","maxLength":5000,"minLength":5,"title":"User Input","description":"用戶需求"},"max_rounds":{"type":"integer","maximum":5.0,"minimum":1.0,"title":"Max Rounds","description":"最大修改輪數","default":3},"skip_review":{"type":"boolean","title":"Skip Review","description":"是否跳過審查","default":false},"output_docx":{"type":"boolean","title":"Output Docx","description":"是否輸出 docx 檔案","default":true},"output_filename":{"anyOf":[{"type":"string","maxLength":200},{"type":"null"}],"title":"Output Filename","description":"輸出檔名（不含路徑，僅允許 .docx 副檔名）"}},"type":"object","required":["user_input"],"title":"MeetingRequest","description":"開會（完整流程）請求\n\n一鍵完成：需求分析 -> 撰寫 -> 審查 -> 修改 -> 輸出。"},"MeetingResponse":{"properties":{"success":{"type":"boolean","title":"Success"},"session_id":{"type":"string","title":"Session Id"},"requirement":{"anyOf":[{"additionalProperties":true,"type":"object"},{"type":"null"}],"title":"Requirement"},"final_draft":{"anyOf":[{"type":"string"},{"type":"null"}],"title":"Final Draft"},"qa_report":{"anyOf":[{"additionalProperties":true,"type":"object"},{"type":"null"}],"title":"Qa Report"},"output_path":{"anyOf":[{"type":"string"},{"type":"null"}],"title":"Output Path"},"rounds_used":{"type":"integer","title":"Rounds Used","default":0},"error":{"anyOf":[{"type":"string"},{"type":"null"}],"title":"Error"}},"type":"object","required":["success","session_id"],"title":"MeetingResponse","description":"開會回應"},"ParallelReviewRequest":{"properties":{"draft":{"type":"string","maxLength":50000,"minLength":10,"title":"Draft","description":"要審查的公文草稿"},"doc_type":{"type":"string","enum":["函","公告","簽","書函","令","開會通知單","通知"],"title":"Doc Type","description":"公文類型","default":"函"},"agents":{"items":{"type":"string"},"type":"array","title":"Agents","description":"要執行的 Agent 列表（可用值：format, style, fact, consistency, compliance）","default":["format","style","fact","consistency","compliance"]}},"type":"object","required":["draft"],"title":"ParallelReviewRequest","description":"並行審查請求（n8n Split 後用）\n\n同時執行多個審查 Agent，彙整結果。"},"ParallelReviewResponse":{"properties":{"success":{"type":"boolean","title":"Success"},"results":{"additionalProperties":{"$ref":"#/components/schemas/SingleAgentReviewResponse"},"type":"object","title":"Results"},"aggregated_score":{"type":"number","maximum":1.0,"minimum":0.0,"title":"Aggregated Score"},"risk_summary":{"type":"string","enum":["Critical","High","Moderate","Low","Safe"],"title":"Risk Summary"},"error":{"anyOf":[{"type":"string"},{"type":"null"}],"title":"Error"}},"type":"object","required":["success","results","aggregated_score","risk_summary"],"title":"ParallelReviewResponse","description":"並行審查回應"},"RefineRequest":{"properties":{"draft":{"type":"string","maxLength":50000,"minLength":10,"title":"Draft","description":"要修改的公文草稿"},"feedback":{"items":{"additionalProperties":true,"type":"object"},"type":"array","maxItems":20,"title":"Feedback","description":"來自審查的問題列表"}},"type":"object","required":["draft","feedback"],"title":"RefineRequest","description":"修改請求\n\n根據審查意見修改公文草稿。"},"RefineResponse":{"properties":{"success":{"type":"boolean","title":"Success"},"refined_draft":{"anyOf":[{"type":"string"},{"type":"null"}],"title":"Refined Draft"},"error":{"anyOf":[{"type":"string"},{"type":"null"}],"title":"Error"}},"type":"object","required":["success"],"title":"RefineResponse","description":"修改回應"},"RequirementRequest":{"properties":{"user_input":{"type":"string","maxLength":5000,"minLength":5,"title":"User Input","description":"用戶的自然語言需求描述","examples":["幫我寫一份函，台北市環保局發給各學校，關於加強資源回收"]}},"type":"object","required":["user_input"],"title":"RequirementRequest","description":"需求分析請求\n\n將用戶的自然語言描述轉換為結構化的公文需求。"},"RequirementResponse":{"properties":{"success":{"type":"boolean","title":"Success"},"requirement":{"anyOf":[{"additionalProperties":true,"type":"object"},{"type":"null"}],"title":"Requirement"},"error":{"anyOf":[{"type":"string"},{"type":"null"}],"title":"Error"}},"type":"object","required":["success"],"title":"RequirementResponse","description":"需求分析回應"},"ReviewRequest":{"properties":{"draft":{"type":"string","maxLength":50000,"minLength":10,"title":"Draft","description":"要審查的公文草稿"},"doc_type":{"type":"string","enum":["函","公告","簽","書函","令","開會通知單","通知"],"title":"Doc Type","description":"公文類型","default":"函"}},"type":"object","required":["draft"],"title":"ReviewRequest","description":"審查請求\n\n提交公文草稿進行單一 Agent 審查。"},"ReviewResponse":{"properties":{"success":{"type":"boolean","title":"Success"},"agent_name":{"type":"string","title":"Agent Name"},"result":{"anyOf":[{"$ref":"#/components/schemas/SingleAgentReviewResponse"},{"type":"null"}]},"error":{"anyOf":[{"type":"string"},{"type":"null"}],"title":"Error"}},"type":"object","required":["success","agent_name"],"title":"ReviewResponse","description":"審查回應"},"SingleAgentReviewResponse":{"properties":{"agent_name":{"type":"string","title":"Agent Name"},"score":{"type":"number","maximum":1.0,"minimum":0.0,"title":"Score"},"confidence":{"type":"number","maximum":1.0,"minimum":0.0,"title":"Confidence"},"issues":{"items":{"additionalProperties":true,"type":"object"},"type":"array","title":"Issues"},"has_errors":{"type":"boolean","title":"Has Errors"}},"type":"object","required":["agent_name","score","confidence","issues","has_errors"],"title":"SingleAgentReviewResponse","description":"單一 Agent 審查結果"},"ValidationError":{"properties":{"loc":{"items":{"anyOf":[{"type":"string"},{"type":"integer"}]},"type":"array","title":"Location"},"msg":{"type":"string","title":"Message"},"type":{"type":"string","title":"Error Type"},"input":{"title":"Input"},"ctx":{"type":"object","title":"Context"}},"type":"object","required":["loc","msg","type"],"title":"ValidationError"},"WriterRequest":{"properties":{"requirement":{"additionalProperties":true,"type":"object","title":"Requirement","description":"結構化的公文需求（來自 requirement agent）","examples":[{"doc_type":"函","receiver":"臺北市各級學校","sender":"臺北市政府環境保護局","subject":"函轉有關加強校園資源回收工作一案"}]}},"type":"object","required":["requirement"],"title":"WriterRequest","description":"草稿撰寫請求\n\n根據結構化需求（來自 requirement agent）撰寫公文草稿。"},"WriterResponse":{"properties":{"success":{"type":"boolean","title":"Success"},"draft":{"anyOf":[{"type":"string"},{"type":"null"}],"title":"Draft"},"formatted_draft":{"anyOf":[{"type":"string"},{"type":"null"}],"title":"Formatted Draft"},"error":{"anyOf":[{"type":"string"},{"type":"null"}],"title":"Error"}},"type":"object","required":["success"],"title":"WriterResponse","description":"草稿撰寫回應"}}},"tags":[{"name":"健康檢查","description":"伺服器狀態與健康檢查端點"},{"name":"需求分析","description":"將自然語言轉換為結構化公文需求"},{"name":"草稿撰寫","description":